# Document Intelligence -- environment configuration
# Copy to .env and edit as needed.  All values are optional;
# defaults are defined in src/document_intelligence/config/settings.py.

# DI_DEBUG=false
# DI_LOG_LEVEL=INFO

# -- File storage --
# DI_UPLOAD_DIR=data/uploads
# DI_OUTPUT_DIR=data/output
# DI_MAX_UPLOAD_SIZE_MB=50

# -- Extraction engine: "docling" (default) or "chandra" --
# DI_EXTRACTION_ENGINE=docling

# -- Docling options --
# DI_DOCLING_OCR_ENABLED=true
# DI_DOCLING_USE_VLM=false
# DI_DOCLING_VLM_MODEL=granite_docling

# -- Chandra options --
# DI_CHANDRA_METHOD=vllm
# DI_CHANDRA_VLLM_API_BASE=http://localhost:8000/v1

# -- API --
# DI_API_HOST=0.0.0.0
# DI_API_PORT=8000
# DI_API_WORKERS=1
